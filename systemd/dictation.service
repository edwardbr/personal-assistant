[Unit]
Description=Push-to-talk dictation (Right-Ctrl) -> whisper-server -> ydotool
After=whisper-strix-halo.service ydotoold.service graphical-session.target
Wants=whisper-strix-halo.service ydotoold.service
PartOf=graphical-session.target

[Service]
Type=simple
Environment=WHISPER_URL=http://127.0.0.1:8771/v1/audio/transcriptions
Environment=YDOTOOL_SOCKET=%t/.ydotool_socket
Environment=DICTATION_SOCKET_PATH=%h/.cache/personal-assistant/dictation.sock
# Use direct keystroke injection rather than copying transcripts to the clipboard.
Environment=DICTATION_TYPER=direct
Environment=DICTATION_ALLOW_CLIPBOARD_FALLBACK=0
# Only used if DICTATION_TYPER=clipboard. GNOME/text editors use Ctrl+V; terminals use ctrl_shift_v.
Environment=DICTATION_PASTE_KEYS=ctrl_v
ExecStart=%h/projects/personal-assistant/daemon/.venv/bin/python %h/projects/personal-assistant/daemon/dictation.py
Restart=on-failure
RestartSec=2
TimeoutStartSec=15

[Install]
WantedBy=graphical-session.target
